# Nishchinto Test Environment (LOCAL ONLY)
# Usage: export $(cat .env.test | xargs) && python manage.py test

DEBUG=False
SECRET_KEY=test-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Point to localhost because we are running outside Docker
DATABASE_URL=postgres://nishchinto:nishchinto_password@127.0.0.1:5432/nishchinto
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=memory://
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=nishchinto_meili_master_key_dev

# Use local storage for tests
DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage
