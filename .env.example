# ─────────────────────────────────────────────────────────────────────────────
# server/.env.example  —  copy to server/.env and fill in values.
# Used by: docker compose up  /  docker compose -f docker-compose.prod.yml up
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-50+-char-random-string
DEBUG=False
# The public-facing web URL (used in email links, OAuth callbacks, storefront URLs)
WEB_URL=https://yourdomain.com
# Comma-separated: your API domain(s)
ALLOWED_HOSTS=api.yourdomain.com
# Comma-separated: origins allowed CSRF (https required in prod)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
# Comma-separated: origins allowed CORS
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── Postgres (superuser used only to initialize the DB) ───────────────────────
POSTGRES_USER=nishchinto_admin
POSTGRES_PASSWORD=your_strong_superuser_password
POSTGRES_DB=nishchinto

# ── Application DB user (used by Django via PgBouncer) ───────────────────────
APP_DB_USER=nishchinto
APP_DB_PASSWORD=your_strong_app_password

# ── PgBouncer ─────────────────────────────────────────────────────────────────
PGBOUNCER_DB_USER=nishchinto
PGBOUNCER_DB_PASSWORD=your_strong_app_password
PGBOUNCER_DB_NAME=nishchinto
PGBOUNCER_AUTH_TYPE=scram-sha-256
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=500
PGBOUNCER_DEFAULT_POOL_SIZE=20
PGBOUNCER_RESERVE_POOL_SIZE=5
PGBOUNCER_RESERVE_POOL_TIMEOUT=5
PGBOUNCER_SERVER_IDLE_TIMEOUT=300
# IMPORTANT: Must be 0 when using PgBouncer in transaction pool mode.
# Non-zero values cause connection pool exhaustion and FATAL DB errors.
CONN_MAX_AGE=0

# ── Connection URLs (point to Docker service names) ───────────────────────────
# Django connects through PgBouncer, NOT directly to postgres
DATABASE_URL=postgres://nishchinto:your_strong_app_password@pgbouncer:5432/nishchinto
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=amqp://nishchinto:your_rabbitmq_password@rabbitmq:5672//

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=nishchinto
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password

# ── Meilisearch ───────────────────────────────────────────────────────────────
# IMPORTANT: Use Docker service name inside containers (NOT localhost)
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=your_meilisearch_master_key_min_16_chars

# ── S3 / Cloudflare R2 (or AWS S3) ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-r2-or-s3-access-key
AWS_SECRET_ACCESS_KEY=your-r2-or-s3-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=auto
# Leave empty for real AWS S3; set to R2 endpoint for Cloudflare
AWS_S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
CDN_BASE_URL=https://cdn.yourdomain.com

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_smtp_user
EMAIL_HOST_PASSWORD=your_smtp_password

# ── Sentry (optional — error monitoring) ─────────────────────────────────────
SENTRY_DSN=

# ── Meta / Facebook OAuth (v0.4 social connect) ──────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=https://app.yourdomain.com/api/callback/integrations/meta

# ── Google OAuth (v0.1 core auth) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OpenAI (required for AI copywriting, image gen, and RAG chatbot) ─────────
OPENAI_API_KEY=

# ── Meta Webhook Security ─────────────────────────────────────────────────────
# IMPORTANT: Change this from the default — it secures your Meta webhook endpoint.
# Use a random 50+ char string. Anyone who knows this token can spoof webhooks.
META_WEBHOOK_VERIFY_TOKEN=replace-with-random-50-char-string
